# Database
# Use the Supabase pooler URL for runtime/serverless connections.
# Keep `pgbouncer=true` on pooler URLs to avoid prepared statement errors.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?schema=public&pgbouncer=true"

# Use the direct database URL for Prisma migrations.
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Supabase API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-or-publishable-key>"
SUPABASE_SERVICE_ROLE_KEY="<optional-service-role-key>"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<generate-with-openssl-rand-base64-32>"
NEXTAUTH_DEBUG="true"
AUTH_DANGEROUS_EMAIL_LINKING="true"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# Lichess
LICHESS_ENABLED="true"
LICHESS_CLIENT_ID=""
LICHESS_CLIENT_SECRET=""
